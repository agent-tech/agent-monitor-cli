{
  "name": "@agenttech/quay-cli",
  "version": "0.2.0",
  "description": "Quay — terminal client for browsing agent activity (global stats, agent listings, detail, search, transactions).",
  "keywords": [
    "cli",
    "quay",
    "agent",
    "bun"
  ],
  "license": "MIT",
  "author": "mini-shrimp",
  "homepage": "https://github.com/agent-tech/agent-monitor-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-tech/agent-monitor-cli.git"
  },
  "bugs": {
    "url": "https://github.com/agent-tech/agent-monitor-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "quay": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "start": "bun run index.ts",
    "build": "bun build ./index.ts --outfile dist/cli.js --target node --minify --banner \"#!/usr/bin/env node\" && bun run build:chmod",
    "build:chmod": "node -e \"try{require('fs').chmodSync('dist/cli.js',0o755)}catch(e){}\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "bun run clean && bun run build",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "typescript": "^5"
  }
}
